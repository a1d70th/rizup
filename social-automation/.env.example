# ── Rizup Social Automation 環境変数テンプレ ──
# コピーして `.env.local` として保存（git 管理外）

# ── Threads（Meta Graph API） ──────────────────────
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── X / Twitter（Developer Portal） ─────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Claude API（オプション・AI投稿文生成用）──────
ANTHROPIC_API_KEY=

# ── 通知（オプション。設定すると投稿完了時に通知）─
DISCORD_WEBHOOK_URL=
RESEND_API_KEY=
NOTIFY_EMAIL=
FROM_EMAIL=
