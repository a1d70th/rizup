# ========================================================================
# Rizup v3.1 本番環境変数（Vercel Environment Variables にそのまま登録）
# Vercel Dashboard → Project → Settings → Environment Variables
# Environment: Production（必要に応じて Preview/Development も）
# ========================================================================

# ── Supabase（必須） ─────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://pcysqlvvqqfborgymabl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.yyy

# ── Claude API（Sho Insight / モデレーション / ビジョン AI アドバイス） ─
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-zzz

# ── Stripe（プラン決済・Webhook） ────────────────────────────────────
# dashboard.stripe.com → Developers → API keys / Products / Webhooks
STRIPE_SECRET_KEY=sk_live_aaa
STRIPE_WEBHOOK_SECRET=whsec_bbb
STRIPE_PRO_PRICE_ID=price_1TJrqX2L4WVM0isfmmryC15w
STRIPE_PREMIUM_PRICE_ID=price_1TJrr92L4WVM0isfGz0qxfpn

# ── Vercel Cron（毎朝7時 Sho プッシュ） ─────────────────────────────
# vercel.json の cron を守るシークレット（任意文字列）
CRON_SECRET=rizup-cron-$(openssl rand -hex 16)

# ── Resend（通報メール通知・サインアップ自動返信） ─────────────────
# resend.com → API Keys
RESEND_API_KEY=re_ccc
FROM_EMAIL=noreply@rizup.app
